# WhatsApp Business API (single platform number)
WHATSAPP_VERIFY_TOKEN=tu_token_de_verificacion
WHATSAPP_API_TOKEN=tu_token_de_api
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_DISPLAY_PHONE=5215551234567
# Meta App Secret (Settings → Basic → App Secret en Meta for Developers).
# Si está vacío en dev, la validación HMAC del POST /webhook se salta.
# REQUERIDO en prod.
WHATSAPP_APP_SECRET=

# Platform
PLATFORM_URL=https://fidel.app

# AI — Procesamiento de fotos de facturas/tickets con Gemini
# Modelo: gemini-2.0-flash (mejor precio/calidad para vision)
# No se usa para conversacion — solo analisis de imagenes
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth (login/registro con Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Database
DATABASE_URL=postgres://loyalty:loyalty@localhost:5433/loyalty?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# S3/MinIO (local dev uses MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=loyalty-invoices
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Server
PORT=8080
ENV=development

# API Auth
BEARER_TOKEN=dev-token-change-in-production
JWT_SECRET=super-secret-jwt-key-change-in-production

# Password reset por email (FID-16)
# EMAIL_PROVIDER: backend de envío. "stdout" (default) sólo loguea el enlace
#   a consola — útil en dev. Integrar un proveedor real es FID-17.
# EMAIL_FROM: dirección From: de los correos.
# APP_URL: base pública del panel admin; se usa para armar el enlace de reset
#   (<APP_URL>/reset-password?token=...). En dev el SPA corre en Vite :5173.
EMAIL_PROVIDER=stdout
EMAIL_FROM=no-reply@fidel.app
APP_URL=http://localhost:5173

# =============================================================================
# .env.deploy.example — Template para el despliegue a producción (Plan A · GCP)
#
# Cómo usar:
#   1. cp .env.deploy.example .env.deploy
#   2. Llena los valores reales (.env.deploy está gitignored).
#   3. `set -a && . ./.env.deploy && set +a` antes de correr los comandos
#      del runbook (~/.claude/plans/nifty-drifting-toast.md).
#
# Las secciones siguen el orden de las fases del plan.
# =============================================================================

# ───────────── Fase 1.1 — Variables globales del proyecto GCP ────────────────
PROJECT_ID=fidel-mvp                      # único globalmente; cámbialo si está tomado
REGION=us-central1
SERVICE=fidel-quick
DB_INSTANCE=fidel-db
ARTIFACT_REPO=fidel-repo
BUCKET=fidel-fidel-mvp-invoices           # debe ser único globalmente

# ───────────── Fase 1.2 — Billing ────────────────────────────────────────────
# Lista con: gcloud billing accounts list
GCP_BILLING_ACCOUNT=                       # ej. 0X0X0X-0X0X0X-0X0X0X

# ───────────── Fase 1.4 — Secrets generados ──────────────────────────────────
# Genera con: openssl rand -base64 24/32 | hex 24/16
DB_PASSWORD=
JWT_SECRET=
BEARER_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ───────────── Fase 2.1 — Upstash Redis ──────────────────────────────────────
# Construye desde el Endpoint + Password en console.upstash.com
# Formato: rediss://default:<PASSWORD>@<HOST>:<PORT>
REDIS_URL=

# ───────────── Fase 2.2 — Meta WhatsApp Business ─────────────────────────────
# Meta for Developers → tu App → WhatsApp → API Setup / Configuration
WHATSAPP_API_TOKEN=                        # System User token o temporary access token
WHATSAPP_PHONE_NUMBER_ID=                  # ID del número (no el +1234... sino el ID numérico)
WHATSAPP_DISPLAY_PHONE=+5215555550000      # con + y código país, formato E.164
# Meta App Settings → Basic → App Secret
WHATSAPP_APP_SECRET=

# ───────────── Fase 2.2 — AI / OAuth ─────────────────────────────────────────
# Google AI Studio → API keys
GEMINI_API_KEY=
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=                          # ej. xxxxxxxx.apps.googleusercontent.com

# ───────────── Fase 5 — Cloud Run (derivados; no editar) ─────────────────────
# Estas dos las usa el comando gcloud run deploy y se derivan de las anteriores;
# se llenan automáticamente si exportas las variables y dejas que tu shell las
# expanda en el comando. Si prefieres, descomenta y déjalas explícitas:
# SERVICE_URL=                              # se obtiene tras `gcloud run deploy`
# CLOUD_SQL_CONNECTION=fidel-mvp:us-central1:fidel-db

# =============================================================================
# Variables de configuracion — copiar a terraform.tfvars y llenar
# =============================================================================
#
# Uso:
#   1. cp plan-a-mvp-minimo.tf main.tf
#   2. cp terraform.tfvars.example terraform.tfvars
#   3. Edita terraform.tfvars con tus valores reales (.tfvars está gitignored).
#   4. terraform init && terraform apply
#
# =============================================================================

project_id = "fidel-495520"
region     = "us-central1"

# Cloud Storage bucket (único globalmente; vacío usa "<project>-loyalty-invoices")
bucket_name = "fidel-mvp-invoice"

# PostgreSQL
db_password = "GENERA_UN_PASSWORD_SEGURO_AQUI"

# Upstash Redis (Plan A — externo)
upstash_redis_url = "rediss://default:xxxxx@xxxxx.upstash.io:6379"

# WhatsApp Business API
whatsapp_api_token       = "EAA..."
whatsapp_verify_token    = "tu_token_de_verificacion"
whatsapp_phone_number_id = "tu_phone_number_id"
whatsapp_display_phone   = "+15551870179"
# Meta App Settings → Basic → App Secret (FID-25 HMAC validation)
whatsapp_app_secret      = "abc..."

# Auth
jwt_secret   = "genera-un-secret-largo-y-aleatorio"
bearer_token = "genera-un-bearer-token-seguro"

# AI (procesamiento de fotos de facturas con Gemini Vision)
gemini_api_key = "AIza..."

# Google OAuth (login del admin con Google — FID-11). Es público; no es secret.
google_client_id = "xxxxxxxx.apps.googleusercontent.com"

# Docker image — déjalo con el placeholder en el primer apply.
# Después del primer build, actualízalo y vuelve a aplicar:
# container_image = "us-central1-docker.pkg.dev/fidel-495520/fidel-repo/fidel-quick:v1"
